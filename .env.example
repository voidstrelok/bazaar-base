# Cliente
STORE_NAME=Mi Tienda

# Puertos (cambiar por cliente para evitar conflictos)
FRONTEND_PORT=3000
API_PORT=5000
DB_PORT=1433

# Base de datos
DB_NAME=TiendaDB
SA_PASSWORD=YourStrong@Passw0rd

# JWT
JWT_SECRET=cambia_este_secreto_seguro
JWT_ISSUER=TiendaApi
JWT_AUDIENCE=TiendaApiUsers
JWT_EXPIRY_MINUTES=60

# Pagos (transbank | mercadopago)
PAYMENT_GATEWAY=transbank

# Storage (cloudinary | local)
STORAGE_PROVIDER=cloudinary
CLOUDINARY_URL=cloudinary://api_key:api_secret@cloud_name

# Storage local (si STORAGE_PROVIDER=local)
LOCAL_STORAGE_PATH=/app/uploads

# CORS
CORS_ORIGINS=http://localhost:3000

# Admin inicial (seed)
ADMIN_EMAIL=admin@tienda.com
ADMIN_PASSWORD=Admin@123456
ADMIN_NOMBRE=Administrador

# Checkout y carrito
ENABLE_CHECKOUT=true

# Botón de contacto (cuando ENABLE_CHECKOUT=false)
# CONTACT_TYPE: whatsapp | email | none
CONTACT_TYPE=whatsapp
CONTACT_VALUE=56912345678
CONTACT_MESSAGE=Hola, me interesa el producto: {nombre}
